# Copy to .env.local (git-ignored) and fill in from your Supabase project
# (Supabase Dashboard → Project Settings → API).

# Client-side (safe to expose; protected by row-level security):
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side ONLY (never expose to the browser). Used by the price function to
# write the shared instrument_meta / price_history tables, and by the keep-alive
# cron. Set these in Vercel → Project → Settings → Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# "Ask about my portfolio" assistant — free Groq API key (console.groq.com, no
# card needed). Server-side only; shared by all signed-in users of the app.
GROQ_API_KEY=your-groq-api-key
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
